rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /schools/{schoolId} {
      allow read, write: if true;
    }
    match /sections/{sectionId} {
      allow read, write: if true;
    }
    match /versions/{versionId}/sections/{sectionId} {
      allow read, write: if true;
    }
    match /config/{configId} {
      allow read, write: if true;
    }
  }
}
